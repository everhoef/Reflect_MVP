{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "retro-event-envelope.schema.json",
  "title": "RetroEventEnvelope",
  "description": "Top-level SSE event wrapper. Maps to RetroEvent Java record. The payload field varies by event type.",
  "type": "object",
  "required": ["correlationId", "retroId", "type", "sourceId", "timestamp"],
  "properties": {
    "correlationId": {
      "type": "string",
      "description": "Unique event ID, format: evt-xxxxxxxx"
    },
    "retroId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the retro session"
    },
    "type": {
      "type": "string",
      "enum": [
        "PARTICIPANT_JOINED", "PARTICIPANT_LEFT", "SESSION_STARTED", "STEP_ADVANCED",
        "RETRO_CREATED", "PHASE_STARTED", "NOTE_ADDED", "NOTE_UPDATED", "NOTE_DELETED",
        "VOTE_ADDED", "VOTE_REMOVED", "GROUP_CREATED", "GROUP_UPDATED", "GROUP_DELETED",
        "ACTION_CREATED", "ACTION_UPDATED", "ACTION_DELETED",
        "TIMER_STARTED", "TIMER_PAUSED", "TIMER_FINISHED"
      ],
      "description": "SSE event type name (matches RetroEvent.EventType enum)"
    },
    "sourceId": {
      "type": "string",
      "description": "ID of the entity that triggered this event (participant ID or 'system')"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event was created"
    },
    "payload": {
      "description": "Event-specific payload. Type depends on event type. Null for void events."
    }
  },
  "additionalProperties": false
}
